# Copy this file to backend/.env and fill in your real values.
#
# NVIDIA hosted API (https://build.nvidia.com / https://integrate.api.nvidia.com)
# is OpenAI-compatible — LangChain's ChatNVIDIA and the OpenAI client both
# work out of the box.

# Required
NVIDIA_API_KEY=nvapi-...

# Optional — defaults match the BimBam chatbot stack.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/nv-embed-v1
CHAT_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1

# Pinecone Serverless (vector store)
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX_NAME=bimbam-docs
PINECONE_NAMESPACE=bimbam_docs

# DOCUMENTS_DIR=documents   # por defecto apunta a ../documents/
CHUNK_SIZE=600
CHUNK_OVERLAP=80

RETRIEVER_K=4
SIMILARITY_THRESHOLD=0.3

LOG_LEVEL=INFO
REQUEST_TIMEOUT=30.0