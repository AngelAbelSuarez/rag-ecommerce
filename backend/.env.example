# Copy this file to backend/.env and fill in your real values.

# Required
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — defaults match the BimBam chatbot stack.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=llama-nemotron-embed-vl-1b-v2:free
CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

CHROMA_PERSIST_DIR=chroma_db
COLLECTION_NAME=bimbam_docs

# DOCUMENTS_DIR=documents   # por defecto apunta a ../documents/
CHUNK_SIZE=600
CHUNK_OVERLAP=80

RETRIEVER_K=4
SIMILARITY_THRESHOLD=0.3

LOG_LEVEL=INFO
REQUEST_TIMEOUT=30.0
